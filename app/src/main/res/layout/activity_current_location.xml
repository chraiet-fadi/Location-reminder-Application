<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_screen_background"
    android:fillViewport="true"
    tools:context=".CurrentLocationActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="40dp">

        <LinearLayout
            android:id="@+id/currentLocationContent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="640dp">

            <TextView
                android:id="@+id/currentLocationTitleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Current GPS Location"
                android:textColor="@color/app_primary_dark"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/currentLatitudeTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="@drawable/panel_background"
                android:gravity="center"
                android:padding="16dp"
                android:text="@string/latitude_loading"
                android:textColor="@color/app_primary_dark"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/currentLongitudeTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/panel_background"
                android:gravity="center"
                android:padding="16dp"
                android:text="@string/longitude_loading"
                android:textColor="@color/app_primary_dark"
                android:textSize="20sp" />

            <WebView
                android:id="@+id/currentLocationMapWebView"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/map_panel_background" />

            <Button
                android:id="@+id/refreshLocationButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/primary_button_background"
                android:text="Refresh GPS Location"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/addReminderHereButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/secondary_button_background"
                android:text="Add Reminder Here"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
