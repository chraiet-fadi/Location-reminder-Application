<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_screen_background"
    android:fillViewport="true"
    tools:context=".AddReminderActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="40dp">

        <LinearLayout
            android:id="@+id/addReminderContent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="640dp">

            <TextView
                android:id="@+id/addReminderTitleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add Reminder"
                android:textColor="@color/app_primary_dark"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/addReminderSubtitleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Tap the map or use your current GPS position."
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/reminderTitleEditText"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:hint="Reminder title"
                android:background="@drawable/input_background"
                android:inputType="textCapSentences"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <TextView
                android:id="@+id/selectedLocationTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/panel_background"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:padding="16dp"
                android:text="No location selected yet."
                android:textColor="@color/app_primary_dark"
                android:textSize="16sp" />

            <WebView
                android:id="@+id/reminderMapWebView"
                android:layout_width="match_parent"
                android:layout_height="340dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/map_panel_background" />

            <Button
                android:id="@+id/useCurrentLocationButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/app_accent"
                android:text="Use My Current Location"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:cornerRadius="14dp" />

            <Button
                android:id="@+id/saveReminderButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/app_primary"
                android:text="Save Reminder"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                app:cornerRadius="14dp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
